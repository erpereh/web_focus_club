rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    match /users/{uid} {
      allow read: if (isVerified() && request.auth.uid == uid) || isAdmin();
      // Registration creates the profile before email verification.
      allow create: if isSignedIn() && request.auth.uid == uid;
      // A verified user can update their own profile, but not their role.
      allow update: if (
        isVerified()
        && request.auth.uid == uid
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // APPOINTMENTS
    match /appointments/{appointmentId} {
      allow create: if isAdmin()
        || (
          isVerified()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.status == 'pending'
        );

      allow read: if (isVerified() && resource.data.userId == request.auth.uid)
        || isAdmin()
        || isAssignedTrainer(resource);

      allow update: if isAdmin()
        || (isTrainer()
          && isAssignedTrainer(resource)
          && onlyTrainerNotesChanged());
      allow delete: if isAdmin();
    }

    // TRAINERS
    match /trainers/{trainerId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // BLOCKED SLOTS
    match /blocked_slots/{slotId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // SLOT OCCUPANCY
    match /slot_occupancy/{slotId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // SERVICES
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TESTIMONIALS
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isAdmin();
    }

    // CMS / SITE CONTENT
    match /site_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // GLOBAL SITE CONFIG
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BONOS
    match /bonos/{bonoId} {
      allow read: if (isVerified() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ACTIVITY LOGS
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // MEDIA LIBRARY
    match /media_folders/{folderId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    match /media_files/{fileId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // GALLERY ITEMS
    match /gallery_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SYSTEM CONFIG
    match /system_config/{docId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTrainer() {
      return isVerified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer';
    }

    function isAssignedTrainer(appt) {
      return isVerified()
        && appt.data.assignedTrainer != null
        && isTrainerAssignedByUid(appt.data.assignedTrainer);
    }

    function isTrainerAssignedByUid(trainerId) {
      return get(/databases/$(database)/documents/trainers/$(trainerId)).data.uid == request.auth.uid;
    }

    function onlyTrainerNotesChanged() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['trainerNotes', 'updatedAt']);
    }
  }
}
