rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    match /users/{uid} {
      allow read: if (isVerified() && request.auth.uid == uid) || isAdmin();
      // Registration creates the profile before email verification.
      allow create: if createsOwnUserProfile(uid) || isAdmin();
      allow update: if (isVerified() && request.auth.uid == uid && onlyOwnUserProfileFieldsChanged()) || isAdmin();
      allow delete: if isAdmin();

      match /fcmTokens/{token} {
        allow read: if (isVerified() && request.auth.uid == uid) || isAdmin();
        allow create, update: if (isVerified() && request.auth.uid == uid && isValidOwnFcmToken(token)) || isAdmin();
        allow delete: if (isVerified() && request.auth.uid == uid) || isAdmin();
      }
    }

    // APPOINTMENTS
    match /appointments/{appointmentId} {
      allow create: if isAdmin();

      allow read: if (isVerified() && resource.data.userId == request.auth.uid)
        || isAdmin()
        || isAssignedTrainer(resource);

      allow update: if isAdmin()
        || (isTrainer()
          && isAssignedTrainer(resource)
          && onlyTrainerNotesChanged());
      allow delete: if isAdmin();
    }

    // TRAINERS
    match /trainers/{trainerId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // BLOCKED SLOTS
    match /blocked_slots/{slotId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // SLOT OCCUPANCY
    match /slot_occupancy/{slotId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // SERVICES
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TESTIMONIALS
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAdmin() || (isVerified() && isValidUserTestimonialCreate());
      allow update, delete: if isAdmin();
    }

    // CMS / SITE CONTENT
    match /site_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // GLOBAL SITE CONFIG
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BONOS
    match /bonos/{bonoId} {
      allow read: if (isVerified() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ACTIVITY LOGS
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // MEDIA LIBRARY
    match /media_folders/{folderId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    match /media_files/{fileId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    // GALLERY ITEMS
    match /gallery_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SYSTEM CONFIG
    match /system_config/{docId} {
      allow read: if isVerified() || isAdmin();
      allow write: if isAdmin();
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTrainer() {
      return isVerified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer';
    }

    function isAssignedTrainer(appt) {
      return isVerified()
        && appt.data.assignedTrainer != null
        && isTrainerAssignedByUid(appt.data.assignedTrainer);
    }

    function isTrainerAssignedByUid(trainerId) {
      return get(/databases/$(database)/documents/trainers/$(trainerId)).data.uid == request.auth.uid;
    }

    function onlyTrainerNotesChanged() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['trainerNotes', 'updatedAt']);
    }

    function createsOwnUserProfile(uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'user'
        && (!('isTrainer' in request.resource.data) || request.resource.data.isTrainer == false)
        && (!('pushNotificationsEnabled' in request.resource.data) || request.resource.data.pushNotificationsEnabled is bool)
        && request.resource.data.keys().hasOnly(['uid', 'email', 'name', 'phone', 'role', 'isTrainer', 'photoURL', 'createdAt', 'pushNotificationsEnabled']);
    }

    function onlyOwnUserProfileFieldsChanged() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['name', 'phone', 'photoURL', 'pushNotificationsEnabled'])
        && (!('pushNotificationsEnabled' in request.resource.data) || request.resource.data.pushNotificationsEnabled is bool);
    }

    function isValidOwnFcmToken(token) {
      return request.resource.data.keys().hasOnly(['token', 'platform', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(['token', 'platform', 'createdAt', 'updatedAt'])
        && request.resource.data.token == token
        && request.resource.data.token is string
        && request.resource.data.platform in ['android', 'ios', 'macos', 'web', 'windows', 'linux', 'unknown']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidUserAppointmentCreate() {
      return request.resource.data.keys().hasOnly(['userId', 'name', 'email', 'phone', 'serviceType', 'duration', 'preferredSlots', 'reason', 'status', 'createdAt'])
        && request.resource.data.keys().hasAll(['userId', 'name', 'email', 'phone', 'serviceType', 'duration', 'preferredSlots', 'reason', 'status', 'createdAt'])
        && request.resource.data.duration in ['30', '45', '60']
        && request.resource.data.preferredSlots is list
        && request.resource.data.preferredSlots.size() == 1;
    }

    function isValidUserTestimonialCreate() {
      return request.resource.data.keys().hasOnly(['name', 'role', 'content', 'rating', 'image', 'source', 'approved'])
        && request.resource.data.keys().hasAll(['name', 'role', 'content', 'rating', 'approved'])
        && request.resource.data.approved == false
        && (!('source' in request.resource.data) || request.resource.data.source == 'manual')
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
    }
  }
}
